{
	auto_https off
}

:80 {
	# HTTP actions (port 3211): only specific paths that are Convex HTTP actions
	handle /.well-known/* {
		reverse_proxy {$CONVEX_SITE_UPSTREAM}
	}
	handle /api/auth/* {
		reverse_proxy {$CONVEX_SITE_UPSTREAM}
	}
	handle /api/github-app/* {
		reverse_proxy {$CONVEX_SITE_UPSTREAM}
	}
	handle /api/webhooks/* {
		reverse_proxy {$CONVEX_SITE_UPSTREAM}
	}
	handle /cli/* {
		reverse_proxy {$CONVEX_SITE_UPSTREAM}
	}

	# Storage (port 3210, same upstream as backend): immutable image bytes gated only
	# by an unguessable UUID URL. Override the backend's `private` Cache-Control so
	# shared caches/CDNs can store one copy keyed by the URL.
	handle /api/storage/* {
		reverse_proxy {$CONVEX_BACKEND_UPSTREAM} {
			header_down -Cache-Control
			header_down Cache-Control "public, max-age=31536000, immutable"
		}
	}

	# Everything else -> backend (port 3210): queries, mutations, subscriptions, deploy API
	handle {
		reverse_proxy {$CONVEX_BACKEND_UPSTREAM}
	}
}
