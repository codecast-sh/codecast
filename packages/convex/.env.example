# Self-hosted Convex deployment
CONVEX_SELF_HOSTED_URL=https://your-convex-instance.example.com
CONVEX_SELF_HOSTED_ADMIN_KEY=your-admin-key-here

# Public web app URL (for OAuth redirects)
SITE_URL=https://your-codecast-instance.example.com

# Auth email (Resend)
RESEND_API_KEY=

# AI features
ANTHROPIC_API_KEY=

# Embeddings (optional - Voyage preferred, falls back to OpenAI)
VOYAGE_API_KEY=
OPENAI_API_KEY=

# GitHub App integration (optional)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
