{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-schema-gen/main/schemas/tauri.conf.json",
  "productName": "Codecast",
  "version": "0.1.0",
  "identifier": "sh.codecast.desktop",
  "build": {
    "frontendDist": "https://codecast.sh",
    "devUrl": "http://local.codecast.sh"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Codecast",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["codecast"]
      }
    },
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://codecast.sh/api/desktop/update/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
