# Bundled into production JS by `expo export` / `eas update` (NODE_ENV=production).
# EXPO_PUBLIC_* values are public — this is the self-hosted Convex endpoint, not
# a secret. Without this file, an OTA published from a shell that doesn't export
# the var ships an empty Convex URL and the app can't connect (observed 2026-07-05).
EXPO_PUBLIC_CONVEX_URL=https://convex.codecast.sh
