{
  "name": "@codecast/cli",
  "version": "0.1.0",
  "description": "Sync coding agent conversations to a shared Convex database",
  "type": "module",
  "bin": {
    "codecast": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts src/daemon.ts --outdir dist --target node",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "convex": "^1.17.4",
    "fb-watchman": "^2.0.2",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  }
}
