{
  "name": "@codecast/cli",
  "version": "1.0.24",
  "description": "Sync coding agent conversations to a shared Convex database",
  "type": "module",
  "bin": {
    "codecast": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts src/daemon.ts --outdir dist --target node",
    "build:binary": "bun build src/index.ts --compile --outfile codecast",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@inquirer/prompts": "^8.2.0",
    "chokidar": "^4.0.3",
    "commander": "^12.1.0",
    "convex": "1.31.2",
    "glob": "^13.0.0",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  }
}
