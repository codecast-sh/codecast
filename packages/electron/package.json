{
  "name": "@codecast/electron",
  "version": "1.1.56",
  "description": "Codecast Desktop (Electron)",
  "main": "main.js",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "CODECAST_URL=http://local.codecast.sh electron .",
    "build": "NOTARIZE_KEYCHAIN_PROFILE=codecast electron-builder -m",
    "build:dir": "electron-builder -m --config.mac.target=dir",
    "build:local": "electron-builder -m --config.mac.target=dir --config.mac.identity=null",
    "install:local": "npm run build:local && pkill -f Codecast.app 2>/dev/null; sleep 1 && rm -rf /Applications/Codecast.app && cp -R dist/mac-arm64/Codecast.app /Applications/Codecast.app && xattr -cr /Applications/Codecast.app && echo 'Installed to /Applications'"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "sh.codecast.desktop",
    "productName": "Codecast",
    "files": [
      "main.js",
      "preload.js"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "afterSign": "notarize.js",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "darkModeSupport": true,
      "minimumSystemVersion": "10.15",
      "identity": "Ashot Petrosian (WRG9THCK9Q)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "dmg": {
      "title": "Codecast",
      "artifactName": "Codecast-${version}-arm64.${ext}"
    },
    "protocols": [
      {
        "name": "Codecast",
        "schemes": [
          "codecast"
        ]
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "https://dl.codecast.sh/desktop"
    }
  }
}
