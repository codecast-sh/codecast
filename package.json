{
  "name": "codecast",
  "private": true,
  "license": "MIT",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "cd packages/web && bun run start",
    "dev": "turbo run dev",
    "build": "turbo run build --filter='!@codecast/electron' --filter='!mobile'",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "convex:dev": "cd packages/convex && convex dev",
    "convex:deploy": "cd packages/convex && convex deploy",
    "postinstall": "bash patches/convex-auth-iss-fix.sh"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@codecast/web": "workspace:*",
    "@tanstack/react-virtual": "^3.13.18",
    "convex": "^1.31.6",
    "e2b": "^2.24.0",
    "nanoid": "^5.1.7"
  },
  "overrides": {
    "@radix-ui/react-slot": "1.2.4",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "resolutions": {
    "@radix-ui/react-slot": "1.2.4",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
