{
  "name": "codecast",
  "private": true,
  "packageManager": "bun@1.1.38",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "cd packages/web && bun run start",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "convex:dev": "cd packages/convex && convex dev",
    "convex:deploy": "cd packages/convex && convex deploy"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "convex": "^1.31.6"
  }
}
