worker_processes 1;
error_log /tmp/codecast-nginx-error.log;
pid /tmp/codecast-nginx.pid;

events {
    worker_connections 1024;
}

http {
    access_log /tmp/codecast-nginx-access.log;

    map $host $backend_port {
        local.codecast.sh      3200;
        local.1.codecast.sh    3201;
        local.2.codecast.sh    3202;
        local.3.codecast.sh    3203;
        default                3200;
    }

    server {
        listen 80;
        server_name local.codecast.sh local.1.codecast.sh local.2.codecast.sh local.3.codecast.sh;

        location / {
            proxy_pass http://127.0.0.1:$backend_port;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_read_timeout 86400;
        }
    }
}
